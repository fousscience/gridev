# Sanity (créer un projet sur https://www.sanity.io/manage)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01
# Token lecture (optionnel si dataset public) — pour Studio / draft
SANITY_API_READ_TOKEN=
# Secret partagé avec le webhook Sanity → /api/revalidate
SANITY_REVALIDATE_SECRET=

# Resend (https://resend.com) — formulaire contact
RESEND_API_KEY=
CONTACT_TO_EMAIL=gridevmali@gmail.com
# Domaine vérifié Resend, ex. onboarding@resend.dev en test
CONTACT_FROM_EMAIL=onboarding@resend.dev

# OpenRouter — assistant chat (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# Modèle (défaut : openai/gpt-4o-mini)
OPENROUTER_MODEL=openai/gpt-4o-mini

# URL publique du site (sitemap / metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
